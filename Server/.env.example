# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Used by mailSender.js to send complaint confirmation & password update emails
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_gmail_app_password   # Generate from: Google Account > Security > App Passwords

# ─── Authentication ───────────────────────────────────────────────────────────
# Used to sign & verify JWT tokens for user sessions
JWT_SECRET=your_jwt_secret_key

# ─── Cloudinary (File / Image Storage) ───────────────────────────────────────
# Used to upload and delete complaint photos
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URL="mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/NagrikSetu"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Cloudinary Folder ────────────────────────────────────────────────────────
FOLDER_NAME="FileUpload"
